# 文案引擎（可切 provider）
# LLM_PROVIDER：yunwu（云雾中转，默认）/ deepseek（DeepSeek 官方直连，备用）
LLM_PROVIDER=yunwu
# 云雾中转：一把 key 通 400+ 模型，默认 deepseek-v4-flash（配置见桌面《云雾API-中转.md》）
YUNWU_API_KEY=
YUNWU_API_BASE=https://yunwu.ai/v1
LLM_MODEL=deepseek-v4-flash
# DeepSeek 官方直连备用（LLM_PROVIDER=deepseek 时才需要）
DEEPSEEK_API_KEY=
# Resend 邮件（不填则只生成不发信）
RESEND_API_KEY=
MAIL_TO=
# Cron 鉴权（Vercel Cron 自动带 Bearer $CRON_SECRET）
CRON_SECRET=
# 审核页鉴权（/edit/[date]?key=ADMIN_KEY）
ADMIN_KEY=
# Vercel Blob 读写令牌（连接 Blob store 后自动注入）
BLOB_READ_WRITE_TOKEN=
# 站点地址（邮件里的网页版/审核链接）
SITE_URL=https://daily.saveme505.help
